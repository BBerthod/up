APP_NAME=Up
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=up
DB_USERNAME=postgres
DB_PASSWORD=

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Redis DB isolation — each concern uses a separate logical database
# DB 0 (default): general/locks  DB 1: cache  DB 2: queue  DB 3: sessions
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2
REDIS_SESSION_DB=3

# Queue
QUEUE_CONNECTION=redis
# Explicit Redis connection for queue workers (uses REDIS_QUEUE_DB=2)
REDIS_QUEUE_CONNECTION=queue
# retry_after for the redis_long connection used by RunWarmSite (timeout=600s) and
# RunLighthouseAudit (timeout=180s). Must exceed the longest timeout to prevent
# premature requeue that would defeat ShouldBeUnique and cause duplicate runs.
REDIS_LONG_QUEUE_RETRY_AFTER=700

# Session
SESSION_DRIVER=redis
SESSION_ENCRYPT=false
# Points to the dedicated Redis session connection (REDIS_SESSION_DB=3)
# so volatile-lru eviction on the cache DB never touches active sessions.
SESSION_CONNECTION=session

# Cache
CACHE_STORE=redis

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug
# Production: set LOG_CHANNEL=json to emit structured JSON to stderr
# (consumed by Docker log driver / log aggregators like Loki, Datadog, CloudWatch)
# LOG_CHANNEL=json

# Mail
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@up.dev"
MAIL_FROM_NAME="${APP_NAME}"

# Laravel Reverb (WebSocket)
REVERB_APP_ID=up-local
REVERB_APP_KEY=up-key
REVERB_APP_SECRET=up-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Push Notifications (VAPID)
# Generate with: php artisan webpush:vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VITE_VAPID_PUBLIC_KEY="${VAPID_PUBLIC_KEY}"

# Admin (used by AdminSeeder)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password
ADMIN_NAME=Admin

# Google PageSpeed Insights (optional, higher rate limits with key)
GOOGLE_PAGESPEED_API_KEY=

# PostgreSQL backups (pg-backup service)
# Backups are written to the "backups" Docker volume at 03:00 daily.
# BACKUP_RETENTION_DAYS controls how many daily dumps are kept locally.
# Production: mount the volume to an S3-backed path or use a sidecar to ship to object storage.
BACKUP_RETENTION_DAYS=7
